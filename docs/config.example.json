{
  "project": {
    "root": "/path/to/your/c-project",
    "build_command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build -j4",
    "test_command": "ctest --test-dir build --output-on-failure",
    "build_dir": "build"
  },
  "output_dir": "results/phase0-run",
  "cert_guidelines": [
    "sei-cert-c",
    "sei-cert-cpp"
  ],
  "max_attempts_per_finding": 3,
  "context_max_files": 8,
  "context_max_lines": 240,
  "max_context_rounds": 4,
  "finding_limit": 25,
  "models": [
    {
      "name": "claude-sonnet-5",
      "provider": "anthropic",
      "model_id": "claude-sonnet-5",
      "api_key_env": "ANTHROPIC_API_KEY",
      "max_output_tokens": 4096,
      "temperature": 0.0
    }
  ]
}
